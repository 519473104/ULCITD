{
  "prefix": "cil",
  "dataset": "tsinghua",
  "memory_size": 200,
  "memory_per_class": 20,
  "fixed_memory": false,
  "shuffle": false,
  "init_cls": 2,
  "increment": 2,
  "model_name": "foster_uda",
  "convnet_type": "compact_resnet8",
  "device": ["0"],
  "seed": [21],
  "beta1": 0.96,
  "beta2": 0.97,
  "oofc": "ft",
  "is_teacher_wa": true,
  "lambda_okd": 1,
  "wa_value": 1,
  "init_epochs": 100,
  "init_lr": 0.1,
  "init_weight_decay": 0.0005,
  "boosting_epochs": 50,
  "compression_epochs": 20,
  "lr": 0.1,
  "batch_size": 32,
  "weight_decay": 0.0005,
  "num_workers": 0,
  "T": 2,
  "lambda_pseudo": 1,
  "lambda_fkd": 1,
  "use_uda": true,

  "enable_visualization": false,
  "vis_save_dir": "./visualizations",
  "diagnostics_dir": "./diagnostics",

  "use_pruning": true,
  "pruning_method": "global",
